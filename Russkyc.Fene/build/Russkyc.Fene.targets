<Project>

    <Target Name="HideConsoleAppHost" BeforeTargets="_CreateAppHost">
        <PropertyGroup>
            <_UseWindowsGraphicalUserInterface>true</_UseWindowsGraphicalUserInterface>
        </PropertyGroup>
    </Target>

    <PropertyGroup>
        <PublishIISAssets>false</PublishIISAssets>
        <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
    </PropertyGroup>

    <!-- Fix removal of webview2 desktop framework references -->
    <Target Name="ScrubWebView2DesktopFrameworks" AfterTargets="ResolvePackageAssets" BeforeTargets="ResolveAssemblyReferences;ResolveReferences;CoreCompile">
        <ItemGroup>
            <Reference Remove="@(Reference->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.Wpf'))" />
            <Reference Remove="@(Reference->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.WinForms'))" />

            <ReferencePath Remove="@(ReferencePath->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.Wpf'))" />
            <ReferencePath Remove="@(ReferencePath->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.WinForms'))" />

            <ResolvedCompileFileDefinitions Remove="@(ResolvedCompileFileDefinitions->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.Wpf'))" />
            <ResolvedCompileFileDefinitions Remove="@(ResolvedCompileFileDefinitions->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.WinForms'))" />

            <RuntimeCopyLocalItems Remove="@(RuntimeCopyLocalItems->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.Wpf'))" />
            <RuntimeCopyLocalItems Remove="@(RuntimeCopyLocalItems->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.WinForms'))" />
        </ItemGroup>
    </Target>

    <Target Name="FenePublishScrubber" BeforeTargets="_CopyFilesToPublishDirectory">
        <ItemGroup>
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish->WithMetadataValue('FileName', 'WebView2Loader'))" />
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="'%(ResolvedFileToPublish.Extension)' == '.xml' And $(([System.String]::new('%(ResolvedFileToPublish.Filename)').StartsWith('Microsoft.Web.WebView2')))" />
        </ItemGroup>
    </Target>
</Project>