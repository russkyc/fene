<Project>

    <Target Name="HideConsoleAppHost" BeforeTargets="_CreateAppHost">
        <PropertyGroup>
            <_UseWindowsGraphicalUserInterface>true</_UseWindowsGraphicalUserInterface>
        </PropertyGroup>
    </Target>

    <PropertyGroup>
        <PublishIISAssets>false</PublishIISAssets>
        <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
    </PropertyGroup>

    <Target Name="ScrubWebView2DesktopFrameworks" BeforeTargets="ResolveAssemblyReferences;ResolveReferences;CoreCompile">
        <ItemGroup>
            <Reference Remove="Microsoft.Web.WebView2.Wpf" />
            <Reference Remove="Microsoft.Web.WebView2.WinForms" />

            <ReferencePath Remove="@(ReferencePath)"
                           Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf' Or '%(Filename)' == 'Microsoft.Web.WebView2.WinForms'" />

            <ResolvedCompileFileDefinitions Remove="@(ResolvedCompileFileDefinitions)"
                                            Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf' Or '%(Filename)' == 'Microsoft.Web.WebView2.WinForms'" />
        </ItemGroup>
    </Target>

    <Target Name="FenePublishScrubber" BeforeTargets="_CopyFilesToPublishDirectory">
        <ItemGroup>
            <!-- 1. Force remove the duplicate WebView2Loader from the root publish layout -->
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
                                   Condition="'%(ResolvedFileToPublish.Filename)' == 'WebView2Loader'" />
            <!-- 2. Clean out all leaky WebView2 XML documentation files -->
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
                                   Condition="'%(ResolvedFileToPublish.Extension)' == '.xml' And (String('%(ResolvedFileToPublish.Filename)').StartsWith('Microsoft.Web.WebView2'))" />
            <!-- 3. Strip out development appsettings configurations from production builds -->
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
                                   Condition="'%(ResolvedFileToPublish.Filename)' == 'appsettings.Development'" />
            <!-- 4. Catch-all safety: Ensure no stray PDB files slip through -->
            <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
                                   Condition="'%(ResolvedFileToPublish.Extension)' == '.pdb'" />
        </ItemGroup>
    </Target>
</Project>